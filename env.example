# goai.rest — Environment Variables
# Copy to .env and fill in real values

# R-Keeper 7 Database
RK7_HOST=saturn.carbis.ru
RK7_PORT=7473
RK7_USER=readonly
RK7_PASSWORD=your_rk7_password_here
RK7_DB=RK7

# StoreHouse API
SH_API_URL=http://saturn.carbis.ru:7477/api
SH_API_USER=readonly
SH_API_PASSWORD=your_sh_password_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
